          "order": 2,
          "skill": "reading",
          "prompt": "Put the sentences in natural order.",
          "options": [
            { "id": "A", "text": "그래서 우산을 샀습니다." },
            { "id": "B", "text": "아침에 비가 왔습니다." },
            { "id": "C", "text": "우산이 없었습니다." }
