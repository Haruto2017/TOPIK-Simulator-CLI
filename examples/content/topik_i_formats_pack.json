          "points": 1,
          "explanation": {
            "summary": "It rained in the morning → there was no umbrella → so I bought one. 그래서 signals the result.",
            "grammar": [
              {
                "pattern": "그래서",
                "explanation": "Connects a cause to its result.",
                "example": "비가 왔습니다. 그래서 우산을 샀습니다."
              }
            ]
          }
        },
        {
          "question_id": "f-003",
          "order": 3,
          "skill": "writing",
          "prompt": "Fill in the blanks: 저는 학교(   ) 갑니다. 도서관(   ) 공부합니다.",
          "answer": {
            "type": "cloze",
            "blanks": [
              { "accepted_answers": ["에"] },
              { "accepted_answers": ["에서"] }
            ]
          },
          "points": 2,
          "explanation": {
            "summary": "에 marks a destination with 가다; 에서 marks where an action happens.",
            "grammar": [
              {
                "pattern": "N에 가다 / N에서 V",
                "explanation": "Destination particle versus location-of-action particle.",
                "example": "학교에 갑니다. 도서관에서 공부합니다."
              }
            ],
            "common_mistakes": [
              "Using 에서 with 가다 for a destination."
            ]
          }
        },
