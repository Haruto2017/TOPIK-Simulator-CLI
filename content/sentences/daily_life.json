{
  "schema_version": "topik-sim.sentences.v1",
  "topic": "daily_life",
  "sentences": [
    {
      "id": "daily-001",
      "topic": "daily_life",
      "english": "I get up at seven o'clock.",
      "korean": "저는 일곱 시에 일어나요.",
      "accepted": ["저는 일곱 시에 일어나요.", "저는 일곱 시에 일어납니다.", "일곱 시에 일어나요."],
      "vocabulary": [{ "ko": "일어나다", "en": "to get up" }, { "ko": "시", "en": "o'clock" }],
      "note": "Hours use native numbers (일곱 = seven); the particle **에** marks the time.",
      "level": 1
    },
    {
      "id": "daily-002",
      "topic": "daily_life",
      "english": "I eat breakfast every morning.",
      "korean": "저는 매일 아침을 먹어요.",
      "accepted": ["저는 매일 아침을 먹어요.", "저는 매일 아침을 먹습니다.", "매일 아침을 먹어요."],
      "vocabulary": [{ "ko": "매일", "en": "every day" }, { "ko": "아침", "en": "morning; breakfast" }],
      "note": "**아침** means both \"morning\" and \"breakfast.\"",
      "level": 1
    },
    {
      "id": "daily-003",
      "topic": "daily_life",
      "english": "I go to school by bus.",
      "korean": "저는 버스로 학교에 가요.",
      "accepted": ["저는 버스로 학교에 가요.", "저는 버스로 학교에 갑니다.", "버스로 학교에 가요."],
      "vocabulary": [{ "ko": "버스", "en": "bus" }, { "ko": "학교", "en": "school" }],
      "note": "**(으)로** marks the means (\"by bus\"); **에** marks the destination.",
      "level": 1
    },
    {
      "id": "daily-004",
      "topic": "daily_life",
      "english": "I study Korean.",
      "korean": "저는 한국어를 공부해요.",
      "accepted": ["저는 한국어를 공부해요.", "저는 한국어를 공부합니다.", "한국어를 공부해요."],
      "vocabulary": [{ "ko": "한국어", "en": "Korean (language)" }, { "ko": "공부하다", "en": "to study" }],
      "note": "The object particle **를** marks 한국어.",
      "level": 1
    },
    {
      "id": "daily-005",
      "topic": "daily_life",
      "english": "I read a book at the library.",
      "korean": "저는 도서관에서 책을 읽어요.",
      "accepted": ["저는 도서관에서 책을 읽어요.", "저는 도서관에서 책을 읽습니다.", "도서관에서 책을 읽어요."],
      "vocabulary": [{ "ko": "도서관", "en": "library" }, { "ko": "읽다", "en": "to read" }],
      "note": "**에서** marks where an action happens.",
      "level": 1
    },
    {
      "id": "daily-006",
      "topic": "daily_life",
      "english": "I meet a friend in the evening.",
      "korean": "저녁에 친구를 만나요.",
      "accepted": ["저녁에 친구를 만나요.", "저는 저녁에 친구를 만나요.", "저녁에 친구를 만납니다."],
      "vocabulary": [{ "ko": "저녁", "en": "evening" }, { "ko": "친구", "en": "friend" }],
      "note": "Time word + **에**: 저녁에 = \"in the evening.\"",
      "level": 1
    },
    {
      "id": "daily-007",
      "topic": "daily_life",
      "english": "Today the weather is good.",
      "korean": "오늘은 날씨가 좋아요.",
      "accepted": ["오늘은 날씨가 좋아요.", "오늘은 날씨가 좋습니다.", "오늘 날씨가 좋아요."],
      "vocabulary": [{ "ko": "오늘", "en": "today" }, { "ko": "날씨", "en": "weather" }],
      "note": "Double-subject pattern: topic 오늘은 + subject 날씨가.",
      "level": 1
    },
    {
      "id": "daily-008",
      "topic": "daily_life",
      "english": "I go to bed at eleven o'clock.",
      "korean": "저는 열한 시에 자요.",
      "accepted": ["저는 열한 시에 자요.", "저는 열한 시에 잡니다.", "열한 시에 자요."],
      "vocabulary": [{ "ko": "자다", "en": "to sleep" }, { "ko": "시", "en": "o'clock" }],
      "note": "**자다** is \"to sleep\"; 열한 시 = eleven o'clock.",
      "level": 1
    }
  ]
}
