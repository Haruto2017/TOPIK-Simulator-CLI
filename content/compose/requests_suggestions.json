        { "english": "Shall we watch a movie tomorrow?", "korean": "내일 영화를 볼까요?", "accepted": ["내일 영화를 볼까요?", "내일 영화 볼까요?", "내일 영화를 볼까요"] }
      ]
    },
    {
      "id": "req-eupsida",
      "pattern": "-(으)ㅂ시다",
      "meaning": "let's (do something)",
      "example": "점심을 먹읍시다.",
      "example_en": "Let's eat lunch.",
      "note": "Add **-ㅂ시다** to a vowel stem and **-읍시다** to a consonant stem to propose doing something together. It is a confident suggestion, so use it with friends or juniors rather than elders.",
      "match": ["ㅂ시다", "읍시다", "ᆸ시다"],
      "level": 2,
      "sentences": [
        { "english": "Let's eat lunch.", "korean": "점심을 먹읍시다.", "accepted": ["점심을 먹읍시다.", "점심 먹읍시다.", "우리 점심을 먹읍시다."] },
        { "english": "Let's go together.", "korean": "같이 갑시다.", "accepted": ["같이 갑시다.", "우리 같이 갑시다.", "함께 갑시다."] },
        { "english": "Let's study Korean.", "korean": "한국어를 공부합시다.", "accepted": ["한국어를 공부합시다.", "같이 한국어를 공부합시다.", "한국어 공부합시다."] },
        { "english": "Let's read this book together.", "korean": "이 책을 같이 읽읍시다.", "accepted": ["이 책을 같이 읽읍시다.", "이 책을 읽읍시다.", "이 책 같이 읽읍시다."] },
        { "english": "Let's meet tomorrow.", "korean": "내일 만납시다.", "accepted": ["내일 만납시다.", "우리 내일 만납시다.", "내일 같이 만납시다."] }
      ]
    },
    {
