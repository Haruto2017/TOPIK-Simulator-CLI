      "pattern": "-지 마세요",
      "meaning": "please don't (do something)",
      "example": "늦지 마세요.",
      "example_en": "Please don't be late.",
      "note": "Attach **-지 마세요** to a verb stem to politely tell someone not to do something. The stem stays the same no matter what it ends in.",
      "match": ["지 마세요", "지 마"],
      "level": 1,
      "sentences": [
        { "english": "Please don't be late.", "korean": "늦지 마세요.", "accepted": ["늦지 마세요.", "늦지 마요."] },
        { "english": "Please don't worry.", "korean": "걱정하지 마세요.", "accepted": ["걱정하지 마세요.", "걱정 마세요.", "걱정하지 마요."] },
        { "english": "Please don't smoke here.", "korean": "여기에서 담배를 피우지 마세요.", "accepted": ["여기에서 담배를 피우지 마세요.", "여기서 담배를 피우지 마세요.", "여기에서 담배 피우지 마세요."] },
        { "english": "Please don't open the door.", "korean": "문을 열지 마세요.", "accepted": ["문을 열지 마세요.", "문 열지 마세요."] },
        { "english": "Please don't forget.", "korean": "잊지 마세요.", "accepted": ["잊지 마세요.", "잊어버리지 마세요.", "잊지 마요."] }
      ]
    },
    {
      "id": "req-jusigesseoyo",
      "pattern": "-아/어 주시겠어요?",
      "meaning": "could you please do it (for me)?",
      "example": "창문을 닫아 주시겠어요?",
      "example_en": "Could you please close the window?",
      "note": "Swap **주세요** for **주시겠어요?** to make a request softer and more polite — closer to \"could you…?\" than \"please do.\" It is handy for strangers and formal settings.",
      "match": ["주시겠어요", "주시겠습니까"],
      "level": 2,
      "sentences": [
        { "english": "Could you please close the window?", "korean": "창문을 닫아 주시겠어요?", "accepted": ["창문을 닫아 주시겠어요?", "창문 좀 닫아 주시겠어요?", "창문을 닫아 주시겠어요"] },
        { "english": "Could you please say it again?", "korean": "다시 말해 주시겠어요?", "accepted": ["다시 말해 주시겠어요?", "다시 한 번 말해 주시겠어요?", "다시 말해 주시겠어요"] },
        { "english": "Could you please wait a moment?", "korean": "잠깐 기다려 주시겠어요?", "accepted": ["잠깐 기다려 주시겠어요?", "잠시 기다려 주시겠어요?", "잠깐 기다려 주시겠어요"] },
        { "english": "Could you please help me?", "korean": "좀 도와 주시겠어요?", "accepted": ["좀 도와 주시겠어요?", "저를 도와 주시겠어요?", "좀 도와 주시겠어요"] },
        { "english": "Could you please teach me Korean?", "korean": "한국어를 가르쳐 주시겠어요?", "accepted": ["한국어를 가르쳐 주시겠어요?", "한국어 좀 가르쳐 주시겠어요?", "한국어를 가르쳐 주시겠어요"] }
      ]
    }
