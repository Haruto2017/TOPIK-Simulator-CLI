        { "english": "Please come in.", "korean": "들어오세요.", "accepted": ["들어오세요.", "안으로 들어오세요."] },
        { "english": "Please read this book.", "korean": "이 책을 읽으세요.", "accepted": ["이 책을 읽으세요.", "이 책 읽으세요."] },
        { "english": "Please wait a moment.", "korean": "잠깐 기다리세요.", "accepted": ["잠깐 기다리세요.", "잠시 기다리세요.", "잠깐만 기다리세요."] },
        { "english": "Please take this medicine.", "korean": "이 약을 드세요.", "accepted": ["이 약을 드세요.", "이 약 드세요."] }
      ]
    },
    {
      "id": "req-juseyo",
