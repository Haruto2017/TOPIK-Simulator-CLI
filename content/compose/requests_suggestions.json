    {
      "id": "req-euseyo",
      "pattern": "-(으)세요",
      "meaning": "please do (polite command)",
      "example": "여기 앉으세요.",
      "example_en": "Please sit here.",
      "note": "Attach **-으세요** to a consonant stem and **-세요** to a vowel stem to politely tell someone to do something themselves.",
      "match": ["으세요", "세요"],
      "level": 1,
      "sentences": [
