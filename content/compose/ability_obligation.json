      "sentences": [
        { "english": "May I go in?", "korean": "들어가도 돼요?", "accepted": ["들어가도 돼요?", "들어가도 됩니까?", "들어가도 될까요?"] },
        { "english": "May I sit here?", "korean": "여기에 앉아도 돼요?", "accepted": ["여기에 앉아도 돼요?", "여기에 앉아도 됩니까?", "여기 앉아도 돼요?"] },
        { "english": "May I take a picture?", "korean": "사진을 찍어도 돼요?", "accepted": ["사진을 찍어도 돼요?", "사진을 찍어도 됩니까?"] },
        { "english": "You may go home now.", "korean": "이제 집에 가도 돼요.", "accepted": ["이제 집에 가도 돼요.", "이제 집에 가도 됩니다."] },
        { "english": "May I open the window?", "korean": "창문을 열어도 돼요?", "accepted": ["창문을 열어도 돼요?", "창문을 열어도 됩니까?"] }
      ]
    }
